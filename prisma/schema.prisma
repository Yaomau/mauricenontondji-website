generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Article {
  id             String   @id @default(cuid())
  title          String
  slug           String   @unique
  excerpt        String?
  content        String?
  coverImage     String?
  tag            String?

  // Status workflow: draft → review → published
  status         String   @default("draft") // draft | review | published

  // SEO fields
  seoTitle       String?
  seoDescription String?
  seoKeywords    String?
  focusKeyword   String?

  // Correction notes (admin internal)
  correctionNotes String?

  publishedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}